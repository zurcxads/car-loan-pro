# App environment
# Allowed values: development, staging, production
NEXT_PUBLIC_APP_ENV=development

# NextAuth
# Local development: http://localhost:3000
# Staging preview: your Vercel preview URL
# Production: https://autoloanpro.co
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=generate-with-openssl-rand-base64-32

# Supabase
# Required in staging and production. Local development can omit these to use mock data.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Plaid API
# Optional for local development. Set real values per environment when enabled.
PLAID_CLIENT_ID=your_client_id_here
PLAID_SECRET=your_secret_here
PLAID_ENV=sandbox
